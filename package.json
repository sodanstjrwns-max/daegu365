{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build && npm run copy:assets",
    "copy:assets": "mkdir -p dist/static/videos && cp -f public/static/videos/*.mp4 dist/static/videos/ 2>/dev/null || true",
    "preview": "wrangler pages dev",
    "deploy": "npm run build:prod && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}